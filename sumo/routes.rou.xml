    <flow id="base_e_2_wheeler_str" type="2_wheeler" begin="0" end="3600" vehsPerHour="270" from="e_in" to="w_out" departLane="best" departPos="random_free"/>
    <flow id="base_e_2_wheeler_lft" type="2_wheeler" begin="0" end="3600" vehsPerHour="180" from="e_in" to="s_out" departLane="best" departPos="random_free"/>
    <flow id="base_e_2_wheeler_rgt" type="2_wheeler" begin="0" end="3600" vehsPerHour="150" from="e_in" to="n_out" departLane="best" departPos="random_free"/>
    <flow id="base_e_3_wheeler_str" type="3_wheeler" begin="0" end="3600" vehsPerHour="135" from="e_in" to="w_out" departLane="best" departPos="random_free"/>
    <flow id="base_e_3_wheeler_lft" type="3_wheeler" begin="0" end="3600" vehsPerHour="90" from="e_in" to="s_out" departLane="best" departPos="random_free"/>
    <flow id="base_e_3_wheeler_rgt" type="3_wheeler" begin="0" end="3600" vehsPerHour="75" from="e_in" to="n_out" departLane="best" departPos="random_free"/>
