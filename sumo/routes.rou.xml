    <flow id="base_s_3_wheeler_str" type="3_wheeler" begin="0" end="3600" vehsPerHour="135" from="s_in" to="n_out" departLane="best" departPos="random_free"/>
    <flow id="base_s_3_wheeler_lft" type="3_wheeler" begin="0" end="3600" vehsPerHour="90" from="s_in" to="w_out" departLane="best" departPos="random_free"/>
    <flow id="base_s_3_wheeler_rgt" type="3_wheeler" begin="0" end="3600" vehsPerHour="75" from="s_in" to="e_out" departLane="best" departPos="random_free"/>
    <flow id="base_s_4_wheeler_str" type="4_wheeler" begin="0" end="3600" vehsPerHour="240" from="s_in" to="n_out" departLane="best" departPos="random_free"/>
    <flow id="base_s_4_wheeler_lft" type="4_wheeler" begin="0" end="3600" vehsPerHour="80" from="s_in" to="w_out" departLane="best" departPos="random_free"/>
    <flow id="base_s_4_wheeler_rgt" type="4_wheeler" begin="0" end="3600" vehsPerHour="80" from="s_in" to="e_out" departLane="best" departPos="random_free"/>
