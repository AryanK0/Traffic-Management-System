    <flow id="surge_1_s_3_wheeler_lft" type="3_wheeler" begin="1000" end="1200" vehsPerHour="360" from="s_in" to="w_out" departLane="best" departPos="random_free"/>
    <flow id="surge_1_s_3_wheeler_rgt" type="3_wheeler" begin="1000" end="1200" vehsPerHour="300" from="s_in" to="e_out" departLane="best" departPos="random_free"/>

