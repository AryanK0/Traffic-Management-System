    <!-- ============================================== -->
    <!-- CHAOTIC SURGE PLATOONS                         -->
    <!-- ============================================== -->
    <!-- Platoon 1: 2_wheeler from N -->
    <flow id="surge_0_n_2_wheeler_str" type="2_wheeler" begin="100" end="300" vehsPerHour="1350" from="n_in" to="s_out" departLane="best" departPos="random_free"/>
    <flow id="surge_0_n_2_wheeler_lft" type="2_wheeler" begin="100" end="300" vehsPerHour="900" from="n_in" to="e_out" departLane="best" departPos="random_free"/>
