    <flow id="base_n_4_wheeler_lft" type="4_wheeler" begin="0" end="3600" vehsPerHour="80" from="n_in" to="e_out" departLane="best" departPos="random_free"/>
    <flow id="base_n_4_wheeler_rgt" type="4_wheeler" begin="0" end="3600" vehsPerHour="80" from="n_in" to="w_out" departLane="best" departPos="random_free"/>
    <flow id="base_n_heavy_vehicle_str" type="heavy_vehicle" begin="0" end="3600" vehsPerHour="85" from="n_in" to="s_out" departLane="best" departPos="random_free"/>
    <flow id="base_n_heavy_vehicle_lft" type="heavy_vehicle" begin="0" end="3600" vehsPerHour="10" from="n_in" to="e_out" departLane="best" departPos="random_free"/>
    <flow id="base_n_heavy_vehicle_rgt" type="heavy_vehicle" begin="0" end="3600" vehsPerHour="5" from="n_in" to="w_out" departLane="best" departPos="random_free"/>

