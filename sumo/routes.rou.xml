    <flow id="base_w_3_wheeler_str" type="3_wheeler" begin="0" end="3600" vehsPerHour="135" from="w_in" to="e_out" departLane="best" departPos="random_free"/>
    <flow id="base_w_3_wheeler_lft" type="3_wheeler" begin="0" end="3600" vehsPerHour="90" from="w_in" to="n_out" departLane="best" departPos="random_free"/>
    <flow id="base_w_3_wheeler_rgt" type="3_wheeler" begin="0" end="3600" vehsPerHour="75" from="w_in" to="s_out" departLane="best" departPos="random_free"/>
    <flow id="base_w_4_wheeler_str" type="4_wheeler" begin="0" end="3600" vehsPerHour="240" from="w_in" to="e_out" departLane="best" departPos="random_free"/>
    <flow id="base_w_4_wheeler_lft" type="4_wheeler" begin="0" end="3600" vehsPerHour="80" from="w_in" to="n_out" departLane="best" departPos="random_free"/>
    <flow id="base_w_4_wheeler_rgt" type="4_wheeler" begin="0" end="3600" vehsPerHour="80" from="w_in" to="s_out" departLane="best" departPos="random_free"/>
